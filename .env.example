PORT=3443
APP_NAME=BloomNote
APP_BASE_URL=https://localhost:3443
JWT_SECRET=replace-with-a-long-random-secret

# Local dev: use FIREBASE_SERVICE_ACCOUNT_PATH
# Vercel: paste the full JSON into FIREBASE_SERVICE_ACCOUNT_JSON instead
FIREBASE_SERVICE_ACCOUNT_PATH=backend/config/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password-or-app-password
SMTP_FROM=your-email@example.com

SSL_KEY_PATH=certs/key.pem
SSL_CERT_PATH=certs/cert.pem
